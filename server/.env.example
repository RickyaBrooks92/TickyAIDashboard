# Copy to `.env` and fill in. `.env` is gitignored — never commit real secrets.
PORT=3001

# Frontend origin the OAuth callback redirects back to.
FRONTEND_URL=http://localhost:5173

# Google OAuth 2.0 — "Web application" credentials from Google Cloud Console.
# The authorized redirect URI in the console must match GOOGLE_REDIRECT_URI below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# The Gemini API key is now Bring-Your-Own-Key: each user pastes it into the
# dashboard Settings (gear icon). It is sent per request as the
# x-ai-provider-key header and is never stored on the server.
